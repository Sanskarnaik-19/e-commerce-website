# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connections
# For Atlas, replace with your mongodb+srv URL. For local, use mongodb://localhost:27017/dbname
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=animysaku

# JWT Token Secrets (Change these in production to long random strings)
JWT_ACCESS_SECRET=access_secret_token_123_otaku
JWT_ACCESS_EXPIRY=1d
JWT_REFRESH_SECRET=refresh_secret_token_456_cyberpunk
JWT_REFRESH_EXPIRY=7d

# Caching Configuration (Redis)
# Leave blank to automatically fall back to the built-in in-memory LRU cache!
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379

# Cloudinary Integration (Image Uploads)
# Leave blank to store images locally inside the uploads/ folder!
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay Integration (Payment Gateway)
# Leave blank to operate pre-paid order checkouts in Offline Mock/COD Sandbox mode!
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Mail Configurations (Nodemailer SMTP OTP reset)
# Leave blank to log generated password-recovery OTPs directly to your console!
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AnimySaku Store" <noreply@animysaku.com>
