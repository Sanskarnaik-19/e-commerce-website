{
  "openapi": "3.0.0",
  "info": {
    "title": "AnimySaku Store API Documentation",
    "version": "1.0.0",
    "description": "High-Fidelity Cyberpunk Anime Merchandise E-Commerce REST API Backend"
  },
  "servers": [
    {
      "url": "http://localhost:5000/api",
      "description": "Local Development Server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["customer", "admin"] },
          "avatar": {
            "type": "object",
            "properties": {
              "public_id": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "animeName": { "type": "string" },
          "category": { "type": "string" },
          "type": { "type": "string", "enum": ["poster", "sticker"] },
          "price": { "type": "number" },
          "discountPrice": { "type": "number" },
          "stockQuantity": { "type": "integer" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "dimensions": { "type": "string" },
          "materialQuality": { "type": "string" },
          "finishType": { "type": "string", "enum": ["matte", "glossy", "both"] },
          "ratings": { "type": "number" },
          "numOfReviews": { "type": "integer" }
        }
      }
    }
  },
  "paths": {
    "/auth/signup": {
      "post": {
        "summary": "Register a new customer",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string", "example": "Goku Otaku" },
                  "email": { "type": "string", "example": "otaku@animysaku.com" },
                  "password": { "type": "string", "example": "otakupassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "User created successfully" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Log in an existing user",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "otaku@animysaku.com" },
                  "password": { "type": "string", "example": "otakupassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token and User details returned successfully" }
        }
      }
    },
    "/products": {
      "get": {
        "summary": "List all catalog products (with search/filters)",
        "tags": ["Products Catalog"],
        "parameters": [
          { "name": "search", "in": "query", "type": "string" },
          { "name": "category", "in": "query", "type": "string" },
          { "name": "animeName", "in": "query", "type": "string" },
          { "name": "type", "in": "query", "type": "string", "enum": ["poster", "sticker"] },
          { "name": "page", "in": "query", "type": "integer", "default": 1 },
          { "name": "limit", "in": "query", "type": "integer", "default": 20 }
        ],
        "responses": {
          "200": { "description": "Successful retrieval of matched catalog" }
        }
      }
    },
    "/cart": {
      "get": {
        "summary": "Retrieve user shopping cart",
        "tags": ["Shopping Cart"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Array of cart items" }
        }
      },
      "post": {
        "summary": "Add or increment item in cart",
        "tags": ["Shopping Cart"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["productId", "quantity"],
                "properties": {
                  "productId": { "type": "string" },
                  "quantity": { "type": "integer", "default": 1 },
                  "finishType": { "type": "string", "enum": ["matte", "glossy"], "default": "matte" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Item added successfully" }
        }
      }
    },
    "/orders/create": {
      "post": {
        "summary": "Place order (Cash on Delivery or prepay via Razorpay)",
        "tags": ["Orders System"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["shippingAddress", "paymentMethod"],
                "properties": {
                  "shippingAddress": {
                    "type": "object",
                    "properties": {
                      "street": { "type": "string" },
                      "city": { "type": "string" },
                      "state": { "type": "string" },
                      "zipCode": { "type": "string" },
                      "phoneNumber": { "type": "string" }
                    }
                  },
                  "paymentMethod": { "type": "string", "enum": ["COD", "Razorpay"] },
                  "couponCode": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "COD Order Placed or prepaid session initialized" }
        }
      }
    },
    "/admin/analytics": {
      "get": {
        "summary": "Generate operational financial & sales reports",
        "tags": ["Admin Dashboard"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "Admin statistics summary" }
        }
      }
    }
  }
}
