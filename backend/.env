NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Required for DB (MongoDB Atlas or local Mongo)
MONGO_URI=mongodb://127.0.0.1:27017/anime_store 

# JWT secrets (set strong random values before deployment)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_SECRET=dev_cookie_secret_change_me

# Optional for product image upload
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional for Razorpay payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
